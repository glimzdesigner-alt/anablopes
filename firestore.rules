rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && (request.auth.token.email == "pernambucoresenhoso@gmail.com" || request.auth.token.email == "admin@anablopes.com");
    }

    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /models/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promotions/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /daily_counts/{date} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if true 
        && request.resource.data.count == resource.data.count + 1
        && request.resource.data.count <= get(/databases/$(database)/documents/settings/global).data.dailyLimit;
      allow create: if true
        && request.resource.data.count == 1
        && 1 <= get(/databases/$(database)/documents/settings/global).data.dailyLimit;
    }

    match /appointments/{document} {
      allow read: if true;
      allow delete: if isAdmin();
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        request.resource.data.status == 'cancelled' &&
        (resource.data.status == 'pending' || resource.data.status == 'confirmed')
      );
      allow create: if true 
        && request.resource.data.keys().hasAll(['clientName', 'clientPhone', 'clientCpf', 'modelId', 'modelName', 'date', 'time', 'status', 'createdAt'])
        && request.resource.data.status == 'pending';
    }

    match /reviews/{document} {
      allow read: if isAdmin() || resource.data.approved == true;
      allow create: if true
        && request.resource.data.keys().hasAll(['clientName', 'rating', 'approved', 'createdAt'])
        && request.resource.data.approved == false
        && request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }
  }
}
